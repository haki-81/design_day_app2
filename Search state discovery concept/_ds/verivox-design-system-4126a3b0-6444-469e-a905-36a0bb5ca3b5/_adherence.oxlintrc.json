{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/brand/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/foundation/**",
              "components/navigation/**",
              "ui_kits/zahnzusatz/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Selawik|VerivoxIcons))/i]",
        "message": "Font not provided by the design system. Available: Selawik, VerivoxIcons."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute > JSXIdentifier[name!=/^(?:severity|children|showCloseAction|onClose|style|key|ref|className|style|children)$/]",
        "message": "<Alert> doesn't accept that prop. Declared props: severity, children, showCloseAction, onClose, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Alert'] > JSXAttribute[name.name='severity'] > Literal[value!=/^(?:success|info|warning|danger)$/]",
        "message": "<Alert> severity must be one of 'success' | 'info' | 'warning' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|solid|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, solid, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brand|neutral|success|info)$/]",
        "message": "<Badge> tone must be one of 'brand' | 'neutral' | 'success' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|children|appearance|size|iconLeft|iconRight|fullWidth|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: text, children, appearance, size, iconLeft, iconRight, fullWidth, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='appearance'] > Literal[value!=/^(?:primary|secondary|tertiary|text)$/]",
        "message": "<Button> appearance must be one of 'primary' | 'secondary' | 'tertiary' | 'text'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|medium)$/]",
        "message": "<Button> size must be one of 'small' | 'medium'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ButtonGroupOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|subLabel|key|ref|className|style|children)$/]",
        "message": "<ButtonGroupOption> doesn't accept that prop. Declared props: label, value, subLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|padding|interactive|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, padding, interactive, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|subLabel|checked|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: label, subLabel, checked, disabled, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|selected|onClick|removable|onRemove|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, icon, selected, onClick, removable, onRemove, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Drawer'] > JSXAttribute > JSXIdentifier[name!=/^(?:isOpen|title|children|footer|onClose|width|key|ref|className|style|children)$/]",
        "message": "<Drawer> doesn't accept that prop. Declared props: isOpen, title, children, footer, onClose, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|className|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|text|style|key|ref|className|style|children)$/]",
        "message": "<IconHeading> doesn't accept that prop. Declared props: icon, text, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|value|placeholder|type|invalid|validationMessage|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, value, placeholder, type, invalid, validationMessage, disabled, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|variant|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: size, variant, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|inverted)$/]",
        "message": "<Logo> variant must be one of 'default' | 'inverted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:isOpen|title|children|footer|onClose|width|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: isOpen, title, children, footer, onClose, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='RadioOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<RadioOption> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='SelectOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<SelectOption> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stepper'] > JSXAttribute > JSXIdentifier[name!=/^(?:steps|currentStep|completedSteps|onStepSelect|style|key|ref|className|style|children)$/]",
        "message": "<Stepper> doesn't accept that prop. Declared props: steps, currentStep, completedSteps, onStepSelect, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|content|placement|triggerIcon|key|ref|className|style|children)$/]",
        "message": "<Tooltip> doesn't accept that prop. Declared props: children, content, placement, triggerIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tooltip'] > JSXAttribute[name.name='placement'] > Literal[value!=/^(?:top|bottom|left|right)$/]",
        "message": "<Tooltip> placement must be one of 'top' | 'bottom' | 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='YesNo'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|value|onChange|yesLabel|noLabel|style|key|ref|className|style|children)$/]",
        "message": "<YesNo> doesn't accept that prop. Declared props: label, hint, value, onChange, yesLabel, noLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='YesNo'] > JSXAttribute[name.name='value'] > Literal[value!=/^(?:yes|no)$/]",
        "message": "<YesNo> value must be one of 'yes' | 'no'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
